import atexit
import os
import time
import queue
import csv
import threading

import gi

gi.require_version("Gst", "1.0")
from gi.repository import Gst, GLib
import logging

Gst.init(None)

logging.basicConfig(
    level=logging.DEBUG,
)


class Recorder:
    def __init__(self, robot,  width=224, height=224, fps=30, directory="./data"):
        self.robot = robot

        self.width = width
        self.height = height
        self.fps = fps
        self.directory = directory
        os.makedirs(self.directory, exist_ok=True)

        self.recording = False
        self.gst_pipeline = None

        self.frame_counter = 0
        self.frame_info_queue = queue.Queue(maxsize = 32)
        self.csv_writer_thread = None

        self.logger = logging.getLogger("Recorder")
        self.logger.setLevel(logging.DEBUG)


        atexit.register(self.stop)

    def _gst_str(self, target_dir):
        assert os.path.isdir(target_dir), "Target directory {} does not exist".format(
            target_dir
        )

        location = os.path.join(target_dir, "frame_%05d.jpg")
        pipeline_str = (
            "nvarguscamerasrc sensor-mode=3 ! video/x-raw(memory:NVMM), width={}, height={}, framerate=30/1 ! ".format(
                self.width, self.height
            )
            + "videorate ! "
            + " video/x-raw(memory:NVMM), framerate={}/1 ! ".format(self.fps)
            + "identity name=frame_sync signal-handoffs=true silent=false ! "
            + "nvjpegenc ! "
            + "multifilesink location={}".format(location)
        )

        self.logger.info("GStreamer pipeline string: {}".format(pipeline_str))

        return pipeline_str

    def start_recording_jpegs(self, recording_name = None):
        assert os.path.isdir(self.directory), "Target directory {} does not exist".format(
            self.directory
        )

        if self.recording:
            self.logger.error("Pipeline is already running.")
            return

        if recording_name is None:
            recording_name = time.strftime("%Y_%m_%d-%H_%M_%S")

        csv_path = os.path.join(self.directory, "{}.csv".format(recording_name))
        images_path = os.path.join(self.directory, recording_name)

        assert not os.path.exists(csv_path), "CSV file {} already exists.".format(csv_path)
        assert not os.path.exists(images_path), "Images directory {} already exists.".format(images_path)


        pipeline_string = self._gst_str(images_path)
        self.gst_pipeline = Gst.parse_launch(pipeline_string)

        bus = self.gst_pipeline.get_bus()
        bus.add_signal_watch()
        bus.connect("message", self._on_bus_message)

        frame_sync = self.gst_pipeline.get_by_name("frame_sync")
        assert frame_sync is not None, "Failed to get frame_sync element from pipeline."

        frame_sync.connect("handoff", self._on_frame_handoff)

        self.gst_pipeline.set_state(Gst.State.PLAYING)
        self.recording = True
        self.logger.info("Started recording images to: {}, and info to {}:".format(images_path, csv_path))

        self._start_csv_writer(csv_path)

        self.loop = GLib.MainLoop()
        try:
            self.logger.info("Camera recording in progress... Press Ctrl+C to stop.")
            self.loop.run()
        except KeyboardInterrupt:
            self.logger.info("Stopping camera recording...")
        finally:
            self.stop()

    def _on_bus_message(self, bus, message):
        t = message.type
        if t == Gst.MessageType.EOS:
            self.logger.info("End-of-stream reached.")
            self.stop()

        elif t == Gst.MessageType.ERROR:
            err, debug = message.parse_error()
            print("GStreamer Error: {}\nDebug Info: {}".format(err, debug))
            self.stop()

    def _on_frame_handoff(self, element, buffer):
        filename = "frame_{:05d}.jpg".format(self.frame_counter)
        timestamp = buffer.pts  

        left_value = self.robot.left_motor.value
        right_value = self.robot.right_motor.value
        assert left_value is not None and right_value is not None, "Motor values should not be None"
        
        frame_info = {
            "filename": filename,
            "timestamp": timestamp,
            "left_motor": left_value,
            "right_motor": right_value,
        }

        try:
            self.frame_info_queue.put(frame_info, block=False)
        except queue.Full:
            self.logger.error("Frame info queue is full (size: {})".format(self.frame_info_queue.qsize()))
            self.logger.error("Last frame info: {}".format(frame_info))
            self.stop()


        self.frame_counter += 1

    def _start_csv_writer(self, csv_path: str):
        def _csv_writer_worker(): 
            assert not os.path.exists(csv_path), "Csv writer: CSV file {} already exists.".format(csv_path)
            with open(csv_path, mode='w', newline='') as csv_file:
                writer = csv.DictWriter(csv_file, fieldnames=["filename", "timestamp", "left_motor", "right_motor"])
                writer.writeheader()

                while True:
                    row_data = self.frame_info_queue.get()

                    if row_data is None:
                        self.logger.info("CSV writer received shutdown signal.")
                        break

                    self.logger.debug("Writing frame info to CSV: {}".format(row_data))
                    writer.writerow(row_data)
                    csv_file.flush()
                    self.frame_info_queue.task_done()

        assert self.csv_thread is None, "CSV writer thread is already running."

        self.csv_thread = threading.Thread(target=_csv_writer_worker, daemon=True)
        self.csv_thread.start()
        self.logger.info("Started CSV writer thread for file: {}".format(csv_path))
        

    def stop(self):
        if self.gst_pipeline and self.recording:
            self.gst_pipeline.send_event(Gst.Event.new_eos())

            time.sleep(0.5)

            self.gst_pipeline.set_state(Gst.State.NULL)
            self.frame_info_queue.put(None)  # Send shutdown signal to CSV writer thread
            self.logger.info("Waiting for CSV writer thread to finish...")

            self.csv_thread.join(timeout=5)
            if self.csv_thread.is_alive():
                self.logger.warning("CSV writer thread did not finish within timeout :(")
            else:
                self.logger.info("CSV writer thread finished successfully.")

            self.recording = False

            self.logger.info("Recording stopped.")


if __name__ == "__main__":
    output_directory = "./test_ouput"
    os.makedirs(output_directory, exist_ok=True)

    recorder = Recorder(width=224, height=224, fps=1)

    recorder.start_recording_jpegs(output_directory)
